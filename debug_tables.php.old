<?php
require_once __DIR__ . '/helpers.php';
$tables = ['blog_posts', 'usuarios', 'mensajes'];
foreach($tables as $t) {
    echo "\nTABLE: $t\n";
    try {
        $stmt = $pdo->query("DESCRIBE $t");
        print_r($stmt->fetchAll(PDO::FETCH_ASSOC));
    } catch(Exception $e) {
        echo "Error: " . $e->getMessage() . "\n";
    }
}
