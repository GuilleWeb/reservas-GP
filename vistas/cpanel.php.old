<style>
  /* Animaciones slide + fade */
  .slide-enter {
    transform: translateX(20px);
    opacity: 0;
  }
  .slide-enter-active {
    transform: translateX(0);
    opacity: 1;
    transition: all 0.3s ease;
  }
  .slide-leave {
    transform: translateX(0);
    opacity: 1;
  }
  .slide-leave-active {
    transform: translateX(-20px);
    opacity: 0;
    transition: all 0.2s ease;
  }
</style>

<script>
const tabs = document.querySelectorAll(".tab-btn");
const tabContent = document.getElementById("tab-content");
const loader = document.getElementById("tab-loader");

/**
 * Carga el contenido de un módulo y actualiza el estilo del botón.
 * @param {string} tabName El nombre del módulo (ej: 'usuarios').
 * @param {HTMLElement} btn El elemento del botón de la pestaña.
 * @param {boolean} [updateUrl=true] Si se debe actualizar la URL (solo true para clicks).
 */
async function loadTab(tabName, btn, updateUrl = true){
    loader.classList.remove("hidden");
    tabContent.classList.add("slide-leave-active");

    // ----------------------------
    // NUEVO: Actualizar la URL si es un click de usuario
    // ----------------------------
    if (updateUrl) {
        const url = new URL(window.location);
        url.searchParams.set('tab', tabName);
        // Usa pushState para cambiar la URL sin recargar
        history.pushState(null, '', url.toString());
    }

    setTimeout(async () => {
        tabContent.classList.remove("slide-leave-active");
        tabContent.classList.add("slide-enter");

        try {
            const res = await fetch(`modulos/cp-${tabName}.php`);
            let html = await res.text();
            tabContent.innerHTML = html;

            // ----------------------------
            // Ejecutar scripts embebidos
            // ----------------------------
            tabContent.querySelectorAll("script").forEach(oldScript => {
                const newScript = document.createElement("script");
                if(oldScript.src){
                    newScript.src = oldScript.src;
                } else {
                    newScript.textContent = oldScript.textContent;
                }
                document.body.appendChild(newScript).parentNode.removeChild(newScript);
            });

        } catch(e) {
            tabContent.innerHTML = `<p class="text-red-600">Error al cargar el módulo ${tabName}</p>`;
        } finally {
            loader.classList.add("hidden");
        }

        requestAnimationFrame(() => {
            tabContent.classList.add("slide-enter-active");
            tabContent.classList.remove("slide-enter");
        });

        setTimeout(() => tabContent.classList.remove("slide-enter-active"), 300);

        // actualizar etiquetas y estilos
        tabs.forEach(t => {
            t.querySelector(".tab-label").classList.add("hidden");
            t.classList.remove("bg-teal-600","text-white");
            t.classList.add("bg-gray-200","text-gray-700");
        });
        
        // Aplicar estilos al botón activo
        if (btn) {
            btn.querySelector(".tab-label").classList.remove("hidden");
            btn.classList.add("bg-teal-600","text-white");
            btn.classList.remove("bg-gray-200","text-gray-700");
        }

    }, 200);
}


// Evento click en tabs
tabs.forEach(btn => {
  // Cuando se hace clic, el tercer parámetro 'updateUrl' es true por defecto
  btn.addEventListener("click", () => loadTab(btn.dataset.tab, btn, true)); 
});


// ----------------------------
// NUEVO: Primer tab activo al cargar (Verifica URL)
// ----------------------------
window.addEventListener("DOMContentLoaded", () => {
    if(tabs.length === 0) return; // Salir si no hay pestañas

    const urlParams = new URLSearchParams(window.location.search);
    const tabFromUrl = urlParams.get('tab');
    
    let activeTabName = tabs[0].dataset.tab; // Default: primer tab
    let activeBtn = tabs[0]; 

    if (tabFromUrl) {
        // Buscar el botón que corresponde al parámetro de la URL
        const foundBtn = document.querySelector(`.tab-btn[data-tab="${tabFromUrl}"]`);
        
        if (foundBtn) {
            activeTabName = tabFromUrl;
            activeBtn = foundBtn;
        }
        // Si tabFromUrl es inválido, se mantiene el valor por defecto (tabs[0])
    }

    // Cargar la pestaña inicial (ya sea desde URL o el primer tab).
    // El tercer parámetro 'updateUrl' es false para no modificar la URL si ya la tiene.
    loadTab(activeTabName, activeBtn, false);
});
</script>
