<?php
// vistas/empleos.php
?>
<div class="max-w-7xl mx-auto my-8">
  <h1 class="text-3xl font-bold text-teal-700 mb-6">Empleos disponibles</h1>
  <div id="empleosGrid" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
</div>

<script>
$(function(){
  $.get('api/api-empleos.php',{action:'list'},function(res){
    if(res.success){
      const grid = $('#empleosGrid').empty();
      res.data.forEach(job=>{
        grid.append(`<div class="bg-white shadow rounded-lg p-4">
          <h2 class="text-xl font-semibold text-teal-700">${job.titulo}</h2>
          <p class="text-gray-600">${job.descripcion}</p>
          <p class="text-sm text-gray-500 mt-1">Ubicacion: <b>${job.sede}</b> | Publicado: <b>${job.fecha_publicacion}</b></p>
          <div class="mt-2">
            <a href="mailto:rrhh@clinica.com?subject=Postulación ${job.titulo}" class="text-teal-600 text-sm">Postularme →</a>
          </div>
        </div>`);
      });
    }
  });
});
</script>
