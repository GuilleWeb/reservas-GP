<?php
// vistas/sedes.php - Módulo Público para visualizar y agendar citas por sede
// Este archivo requiere la librería jQuery y Font Awesome
?>
<script src="https://cdn.tailwindcss.com"></script>
<!-- ASUMIENDO QUE FONT AWESOME ESTÁ CARGADO GLOBALMENTE, ej: <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="..." crossorigin="anonymous" /> -->
<style>
    /* Usando una fuente moderna */
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f7f9fc;
    }
</style>

<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
        <h1 class="text-4xl font-extrabold text-teal-800 tracking-tight sm:text-5xl">
            Encuentra tu Sede Más Cercana
        </h1>
        <p class="mt-4 text-xl text-gray-600">
            Explora nuestras clínicas y agenda tu próxima cita fácilmente.
        </p>
    </div>

    <!-- Cambiado de 2 a 3 columnas en pantallas grandes (lg) -->
    <div id="sedesGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Las tarjetas de sedes se inyectarán aquí -->
        <div id="loading" class="md:col-span-2 lg:col-span-3 text-center text-gray-500 text-lg">
            Cargando información de sedes...
        </div>
    </div>
</div>

<script>
    // Configuración para que el placeholder sea dinámico y funcione correctamente
    const PLACEHOLDER_URL = "https://guillepalma.xo.je/placeholder/api.php?text=";
    
    // Asumimos que la clínica opera en Guatemala (como el ejemplo de Zona 14)
    // Se puede cambiar la región (ej: "Chile", "México") si es necesario.
    const DEFAULT_MAP_COUNTRY = "Guatemala"; 

    // Función para procesar el horario JSON y devolver un string legible
    function formatHorario(jsonHorario) {
        try {
            const horario = JSON.parse(jsonHorario);
            const lunesViernes = horario['lun-vie'];
            
            if (lunesViernes && lunesViernes.inicio && lunesViernes.fin) {
                let text = `Lun-Vie: ${lunesViernes.inicio} a ${lunesViernes.fin}`;
                if (horario['sab'] !== false && horario['sab'] !== undefined && horario['sab'].inicio && horario['sab'].fin) {
                    text += `, Sáb: ${horario['sab'].inicio} a ${horario['sab'].fin}`;
                }
                if (horario['dom'] === false) {
                    text += `, Dom: Cerrado`;
                }
                return text;
            }
        } catch (e) {
            console.error("Error al parsear horario:", e);
        }
        return 'Horario no especificado';
    }

    // Función para generar la URL de Google Maps
    function getMapsUrl(direccion, nombre) {
        // Codifica la dirección completa para la búsqueda en Google Maps
        const query = encodeURIComponent(`${direccion}, ${nombre}, ${DEFAULT_MAP_COUNTRY}`);
        return `https://www.google.com/maps/search/?api=1&query=${query}`;
    }

    $(function() {
        $.get('api/api-sedes.php', {
            action: 'list',
            activos: 1
        }, function(res) {
            $('#loading').remove();
            const grid = $('#sedesGrid');

            if (res.success && res.data.length > 0) {
                res.data.forEach(s => {
                    // Determinar la URL de la imagen
                    const imageUrl = s.imagen && s.imagen.length > null ? 
                                     s.imagen : 
                                     PLACEHOLDER_URL + encodeURIComponent(s.nombre.replace(/[^a-zA-Z0-9 ]/g, ''));
                    
                    // Formatear el horario para mostrarlo
                    const horarioTexto = formatHorario(s.horario);
                    
                    // Generar URL del mapa
                    const mapsUrl = getMapsUrl(s.direccion, s.nombre);
                    
                    const card = $(`
                        <div class="bg-white rounded-xl shadow-lg hover:shadow-2xl transition-shadow duration-300 overflow-hidden border border-gray-100">
                            <!-- Imagen de la Sede (o Placeholder) -->
                            <div class="h-48 bg-gray-100 overflow-hidden">
                                <img src="${imageUrl}" 
                                     alt="Foto de la sede ${s.nombre}" 
                                     class="w-full h-full object-cover transition-transform duration-300 transform hover:scale-105"
                                     onerror="this.onerror=null; this.src='${PLACEHOLDER_URL + encodeURIComponent(s.nombre)}';">
                            </div>
                            
                            <!-- Contenido de la Tarjeta -->
                            <div class="p-6 space-y-3">
                                <h2 class="text-2xl font-bold text-teal-700">${s.nombre}</h2>
                                
                                <!-- Dirección (Icono de Mapa/Marcador) -->
                                <div class="flex items-start text-gray-600">
                                    <i class="fas fa-map-marker-alt w-5 h-5 text-teal-500 mr-3 mt-0.5 flex-shrink-0"></i>
                                    <p class="text-base">${s.direccion}</p>
                                </div>

                                <!-- Horario (Icono de Reloj) -->
                                <div class="flex items-center text-gray-600">
                                    <i class="fas fa-clock w-5 h-5 text-teal-500 mr-3 flex-shrink-0"></i>
                                    <p class="text-sm font-medium text-teal-600">${horarioTexto}</p>
                                </div>
                                
                                <!-- Teléfono (Icono de Teléfono) -->
                                <div class="flex items-center text-gray-600">
                                    <i class="fas fa-phone w-5 h-5 text-teal-500 mr-3 flex-shrink-0"></i>
                                    <p class="text-base">${s.telefono}</p>
                                </div>
                            </div>

                            <!-- Botones -->
                            <div class="p-6 pt-0 flex space-x-4">
                                <!-- Botón para agendar cita -->
                                <a href="citas?sede=${s.id}" 
                                   class="flex-1 block w-full text-center bg-teal-600 text-white font-semibold py-2.5 rounded-lg hover:bg-teal-700 transition duration-300 transform hover:scale-[1.01] shadow-md text-sm">
                                    Agendar Cita 
                                </a>
                                
                                <!-- Botón para Google Maps -->
                                <a href="${mapsUrl}" target="_blank"
                                   class="flex-1 flex items-center justify-center bg-gray-200 text-gray-700 font-semibold py-2.5 rounded-lg hover:bg-gray-300 transition duration-300 transform hover:scale-[1.01] shadow-md text-sm">
                                    <i class="fas fa-map w-5 h-5 mr-1"></i>
                                    Ver en Mapa
                                </a>
                            </div>
                        </div>
                    `);
                    grid.append(card);
                });
            } else {
                 grid.append('<div class="md:col-span-2 lg:col-span-3 text-center text-gray-500 text-lg">No hay sedes activas disponibles en este momento.</div>');
            }
        });
    });
</script>
