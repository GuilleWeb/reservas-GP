<?php
$user = current_user();
$empresa_slug = request_empresa_slug();
$is_tenant_admin = ($user && $empresa_slug && in_array($user['rol'] ?? null, ['admin', 'gerente']));

if (!$is_tenant_admin) {
    echo '<div class="max-w-3xl mx-auto bg-white p-6 rounded-xl shadow">No autorizado.</div>';
    return;
}
?>

