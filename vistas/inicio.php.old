<script>
    $(window).on("scroll", function () {
        const scrollTop = $(this).scrollTop();
        $(".reveal").each(function () {
            const elementTop = $(this).offset().top;
            if (scrollTop > elementTop - $(window).height() + 100) $(this).addClass("visible");
        });
    });

    $(document).ready(function () {
        $(".reveal").each(function () {
            const elementTop = $(this).offset().top;
            if ($(window).scrollTop() > elementTop - $(window).height() + 100) $(this).addClass("visible");
        });
    });

    const PLACEHOLDER_API_BASE = "/placeholder/api.php?text=";
    const PLACEHOLDER_IMG_URL = PLACEHOLDER_API_BASE + "Articulo+Generico";
    const PLACEHOLDER_GALLERY_TEXT = "Galeria";
    const GALLERY_FALLBACK_URL = PLACEHOLDER_API_BASE + PLACEHOLDER_GALLERY_TEXT;

    let currentImageIndex = 0;
    let galleryImages = [];
    let galleryInterval = null;
    const galleryContainer = $('#heroGallery');
    const indicatorsContainer = $('#galleryIndicators');

    function showImage(index) {
        if (!galleryImages.length) return;
        currentImageIndex = (index + galleryImages.length) % galleryImages.length;
        $(galleryImages).each(function (i, img) {
            if (i === currentImageIndex) $(img).addClass('active');
            else $(img).removeClass('active');
        });
        indicatorsContainer.find('.indicator').removeClass('active');
        indicatorsContainer.find(`.indicator[data-index=${currentImageIndex}]`).addClass('active');
    }

    function nextImage() { showImage(currentImageIndex + 1); }
    function prevImage() { showImage(currentImageIndex - 1); }

    function startGallery(data) {
        if (galleryInterval) clearInterval(galleryInterval);
        galleryContainer.empty();
        indicatorsContainer.empty();
        galleryImages = [];

        data.forEach((item, index) => {
            let imageUrl = item.url_imagen || '';
            if (imageUrl && !imageUrl.startsWith('http') && !imageUrl.startsWith('/')) imageUrl = './' + imageUrl;

            const wrapper = $('<div>', {
                class: 'gallery-image flex items-end justify-start bg-gray-200',
                css: { backgroundImage: `url(${imageUrl})`, backgroundSize: 'cover', backgroundPosition: 'center' }
            });

            const imgCheck = $('<img>', { src: imageUrl, class: 'hidden' }).on('error', function () {
                wrapper.css('background-image', `url(${GALLERY_FALLBACK_URL})`);
            });

            const overlay = $('<div>', { class: 'bg-black/50 text-white p-6 w-full' }).append(`
            <h3 class="text-2xl font-bold mb-2">${item.titulo || ''}</h3>
            <p class="text-sm opacity-90">${item.descripcion || ''}</p>
        `);
            wrapper.append(imgCheck, overlay);
            galleryContainer.append(wrapper);
            galleryImages.push(wrapper);

            const indicator = $('<div>', { class: 'indicator', 'data-index': index }).on('click', () => {
                showImage(index);
                if (galleryInterval) clearInterval(galleryInterval);
                galleryInterval = setInterval(nextImage, 5000);
            });
            indicatorsContainer.append(indicator);
        });

        if (galleryImages.length > 0) {
            showImage(0);
            if (galleryImages.length > 1) {
                $('#prevBtn, #nextBtn, #galleryIndicators').show();
                galleryInterval = setInterval(nextImage, 5000);
            } else {
                $('#prevBtn, #nextBtn, #galleryIndicators').hide();
            }
        } else {
            galleryContainer.html(`<div class="w-full h-full bg-gray-200 flex flex-col items-center justify-center text-gray-500"><i class="fas fa-image text-4xl mb-2"></i>No hay imágenes disponibles.</div>`);
            $('#prevBtn, #nextBtn, #galleryIndicators').hide();
        }
    }

    $('#nextBtn').on('click', () => { nextImage(); if (galleryInterval) clearInterval(galleryInterval); galleryInterval = setInterval(nextImage, 5000); });
    $('#prevBtn').on('click', () => { prevImage(); if (galleryInterval) clearInterval(galleryInterval); galleryInterval = setInterval(nextImage, 5000); });

    function loadLatestPosts() {
        $('#loadingPosts').show();
        $.get('api/api-blog.php', { action: 'list', per: 3, page: 1 }, function (res) {
            const grid = $('#postsGrid').empty();
            $('#loadingPosts').hide();

            if (res.success && res.data && res.data.length) {
                res.data.forEach(p => {
                    const match = p.contenido ? p.contenido.match(/<img[^>]+src="([^"]+)"/i) : null;
                    const postImageUrl = p.imagen || (match ? match[1] : PLACEHOLDER_IMG_URL);
                    let text = p.contenido ? p.contenido.replace(/<[^>]*>?/gm, '') : '';
                    const excerpt = text.length > 120 ? text.substring(0, 120) + '...' : text;

                    grid.append(`
                    <article class="bg-white rounded-lg shadow-lg post-card overflow-hidden flex flex-col">
                        <div class="h-48 bg-gray-100 overflow-hidden">
                            <img src="${postImageUrl}" class="w-full h-full object-cover">
                        </div>
                        <div class="p-5 flex-1 flex flex-col">
                            <h3 class="text-xl font-bold text-gray-800 hover:text-teal-700 transition">${p.titulo}</h3>
                            <p class="text-sm text-gray-600 mt-2 flex-1">${excerpt}</p>
                            <div class="mt-4">
                                <a href="blog?id=${p.id}" class="inline-flex items-center text-teal-600 font-semibold text-sm hover:text-teal-800">
                                    Leer artículo <i class="fas fa-chevron-right ml-1 text-xs"></i>
                                </a>
                            </div>
                        </div>
                    </article>
                `);
                });
            } else {
                grid.html('<p class="col-span-full text-center text-gray-500 py-6">No se encontraron publicaciones recientes.</p>');
            }
        });
    }

    function loadEquipo() {
        $.get('api/api-equipo.php', { action: 'list_public' }, function (res) {
            if (res.success && res.data && res.data.length) {
                $('#seccion_equipo').show();
                const grid = $('#equipoGrid').empty();
                res.data.forEach(item => {
                    let img = item.imagen_path ? item.imagen_path : "https://guillepalma.xo.je/placeholder/api.php?text=" + encodeURIComponent(item.nombre);
                    grid.append(`
                    <div class="bg-white shadow-md rounded-xl p-6 text-center hover:shadow-lg transition duration-300 transform hover:-translate-y-1">
                        <img src="${img}" alt="${item.nombre}" class="w-28 h-28 mx-auto rounded-full object-cover mb-4 border-4 border-teal-500">
                        <h3 class="text-lg font-semibold text-gray-800">${item.nombre}</h3>
                        <p class="text-sm text-teal-600 font-medium">${item.especialidad || 'Especialista'}</p>
                        ${item.descripcion ? `<p class="mt-3 text-sm text-gray-500">${item.descripcion}</p>` : ''}
                    </div>
                `);
                });
            }
        });
    }

    function loadResenas() {
        $.get('api/api-resenas.php', { action: 'list_public', limit: 3 }, function (res) {
            if (res.success && res.data && res.data.length) {
                $('#seccion_resenas').show();
                const grid = $('#resenasGrid').empty();
                res.data.forEach(item => {
                    let stars = '';
                    for (let i = 1; i <= 5; i++) stars += i <= item.rating ? '<i class="fas fa-star text-yellow-500 mr-1"></i>' : '<i class="far fa-star text-yellow-300 mr-1"></i>';

                    grid.append(`
                    <div class="bg-white rounded-xl shadow-lg p-6 transition transform hover:-translate-y-2 hover:shadow-xl">
                      <div class="flex items-center mb-4">
                        <div class="w-12 h-12 rounded-full mr-4 border-2 border-teal-600 bg-teal-50 flex items-center justify-center text-teal-600 font-bold">${item.autor.charAt(0)}</div>
                        <div>
                          <h4 class="font-semibold text-gray-800">${item.autor}</h4>
                          <p class="text-xs text-gray-400">Cliente</p>
                        </div>
                      </div>
                      <p class="text-gray-600 italic text-sm">"${item.comentario}"</p>
                      <div class="mt-4 flex text-sm">${stars}</div>
                    </div>
                `);
                });
            }
        });
    }

    $(function () {
        $.get('api/api-galeria.php', { action: 'list', per: 10, page: 1 }, function (res) {
            if (res.success && res.data && res.data.length) startGallery(res.data);
            else startGallery([{ url_imagen: GALLERY_FALLBACK_URL, titulo: 'Nuestras Instalaciones (Fallback)' }]);
        }).fail(() => {
            startGallery([{ url_imagen: GALLERY_FALLBACK_URL, titulo: 'Vista exterior (Fallback)' }]);
        });

        loadLatestPosts();
        loadEquipo();
        loadResenas();

        $('#contactForm').on('submit', function (e) {
            e.preventDefault();
            const data = {
                nombre: $('#contactNombre').val(), email: $('#contactEmail').val(),
                telefono: $('#contactTelefono').val(), asunto: $('#contactAsunto').val(),
                mensaje: $('#contactMensaje').val(),
            };
            $.post('api/api-mensajes.php?action=contacto', data, function (resp) {
                if (resp && resp.success) {
                    alert('Mensaje enviado. Gracias por contactarnos.');
                    $('#contactForm')[0].reset();
                } else alert('No se pudo enviar el mensaje.');
            }).fail(() => alert('No se pudo enviar el mensaje.'));
        });
    });
</script>