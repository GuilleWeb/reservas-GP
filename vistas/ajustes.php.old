$is_superadmin = ($role === 'superadmin' && !$empresa_slug);
$is_tenant_admin = ($empresa_slug && in_array($role, ['admin', 'gerente']));

if (!$is_superadmin && !$is_tenant_admin) {
  echo '<div class="max-w-3xl mx-auto bg-white p-6 rounded-xl shadow">No autorizado.</div>';
  return;
}
