<script>
$(function(){
  const isSuperadmin = <?= $is_superadmin ? 'true' : 'false' ?>;
  const isTenantAdmin = <?= $is_tenant_admin ? 'true' : 'false' ?>;

  function showInfo(msg, ok, target = 'Global'){
    const el = $('#saveInfo' + target);
    el.removeClass('hidden');
    el.toggleClass('text-teal-700', !!ok);
    el.toggleClass('text-red-600', !ok);
    el.text(msg);
    setTimeout(()=>el.addClass('hidden'), 2500);
  }

  function setVal(id, v, fallback=''){
    if(v===undefined || v===null || v==='') $('#'+id).val(fallback);
    else $('#'+id).val(String(v));
  }

  function loadPanelGlobal(){
    if (!isSuperadmin) return;
    $.get('api/superadmin/ajustes.php',{action:'get_panel'},function(res){
      if(!res.success) return;
      const d = res.data || {};
      setVal('system_name', d.system_name, 'Sistema');
      setVal('maintenance_mode', d.maintenance_mode, '0');
      setVal('allow_login', d.allow_login, '1');
      setVal('allow_register', d.allow_register, '1');

      setVal('smtp_host', d.smtp_host, '');
      setVal('smtp_port', d.smtp_port, '587');
      setVal('smtp_user', d.smtp_user, '');
      setVal('smtp_pass', d.smtp_pass, '');
      setVal('smtp_from_email', d.smtp_from_email, '');
      setVal('smtp_from_name', d.smtp_from_name, '');
    },'json');
  }

  function loadPanelTenant(){
    $.get('api/superadmin/ajustes.php',{action:'get_tenant'},function(res){
      if(!res.success) return;
      const d = res.data || {};
      setVal('system_logo_path', d.logo_path, '');
      setVal('ui_primary_color', d.color_principal, '');
      setVal('support_email', d.email_contacto, '');
      setVal('support_phone', d.telefono_contacto, '');
      setVal('public_footer_text', d.texto_footer, '');
      setVal('hero_titulo', d.hero_titulo, '');
      setVal('hero_subtitulo', d.hero_subtitulo, '');
      setVal('hero_btn_texto', d.hero_btn_texto, '');
      setVal('hero_btn_link', d.hero_btn_link, '');
      setVal('mision', d.mision, '');
      setVal('vision', d.vision, '');
      setVal('about_titulo', d.about_titulo, '');
    },'json');
  }

  $('#btnReloadGlobal').click(loadPanelGlobal);
  $('#btnReloadTenant').click(loadPanelTenant);

  $('#panelForm').on('submit', function(ev){
    ev.preventDefault();
    $.post('api/superadmin/ajustes.php', $(this).serialize()+'&action=save_panel', function(res){
      if(res.success){
        showInfo('Guardado con éxito. Refresca para ver cambios.', true, 'Global');
        loadPanelGlobal();
      } else {
        showInfo(res.message||'Error al guardar', false, 'Global');
      }
    },'json');
  });

  $('#tenantForm').on('submit', function(ev){
    ev.preventDefault();
    $.post('api/superadmin/ajustes.php', $(this).serialize()+'&action=save_tenant', function(res){
      if(res.success){
        showInfo('Apariencia guardada. Refresca para ver cambios.', true, 'Tenant');
        loadPanelTenant();
      } else {
        showInfo(res.message||'Error al guardar', false, 'Tenant');
      }
    },'json');
  });

  if (isSuperadmin) loadPanelGlobal();
  loadPanelTenant();
});
</script>
