}

/* Estilos para el calendario (simulación) */
#calendar-container {
    padding: 1rem;
    border-radius: 0.75rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    background-color: #f7fafc;
}
.day-card.disabled {
    cursor: not-allowed;
    opacity: 0.4;
    background-color: #f3f4f6;
    color: #9ca3af;
}

.day-card.today {
