<script>
// --- ESTADO GLOBAL DE LA APLICACIÓN ---
const App = {
    currentStep: 1,
    clientData: {
        pacienteId: null, // NUEVO: ID del paciente (si existe o si se crea)
        nombre: null,
        email: null,
        telefono: null,
        nota: null,
    },
    selectedSede: null,
    selectedDate: null, // YYYY-MM-DD
    selectedTime: null, // HH:MM
    allSedesData: [], 
    occupiedSlots: [], 
    currentCalendarMonth: new Date(), 
    steps: [
        { title: "Seleccionar Sede", id: 1 },
        { title: "Datos Personales", id: 2 },
        { title: "Fecha y Hora", id: 3 },
        { title: "Confirmación", id: 4 }
    ]
};

// --- UTILITIES Y HELPERS ---

/**
 * Muestra una alerta temporal.
 */
function showAlert(message, type) {
    const container = $('#alert-container');
    let bgColor, borderColor, icon;
    switch (type) {
        case 'success': bgColor = 'bg-green-100'; borderColor = 'border-green-400'; icon = 'fas fa-check-circle text-green-600'; break;
        case 'error': bgColor = 'bg-red-100'; borderColor = 'border-red-400'; icon = 'fas fa-times-circle text-red-600'; break;
        default: bgColor = 'bg-blue-100'; borderColor = 'border-blue-400'; icon = 'fas fa-info-circle text-blue-600'; break;
    }
    const alertHtml = `<div class="${bgColor} border-l-4 ${borderColor} text-gray-800 p-4 rounded-lg shadow-md mb-4 flex items-center" role="alert"><i class="${icon} mr-3 text-xl"></i><p>${message}</p></div>`;
    container.html(alertHtml).slideDown();
    setTimeout(() => container.slideUp(300, () => container.empty()), 10000);
}

/**
 * Llama al nuevo endpoint del backend para obtener las horas ya reservadas.
 */
function getOccupiedSlotsForDay(sedeId, fecha) {
    return new Promise(resolve => {
        $.get("api/api-citas.php", {
            action: "get_booked_slots",
            sede_id: sedeId,
            fecha: fecha
        }, function(res) {
            if (res.success && res.data) {
                App.occupiedSlots = res.data; 
                resolve(res.data); // Array de horas HH:MM
            } else {
                console.error("Error al obtener slots ocupados:", res.message || 'API error');
                App.occupiedSlots = [];
                resolve([]);
            }
        }, "json").fail(() => {
            console.error("Error de red al consultar disponibilidad.");
            App.occupiedSlots = [];
            resolve([]);
        });
    });
}

/**
 * Helper para obtener la clave de horario (lun-vie, sab, dom)
 */
function getHorarioKey(dateObj) {
    const dayOfWeek = dateObj.getDay(); // 0 (Dom) to 6 (Sáb)
    if (dayOfWeek >= 1 && dayOfWeek <= 5) return 'lun-vie'; 
    if (dayOfWeek === 6) return 'sab'; 
    if (dayOfWeek === 0) return 'dom'; 
    return null;
}

// --- WIZARD NAVIGATION ---

/**
 * Actualiza la barra lateral de pasos.
 */
function updateWizardSteps() {
    const stepsHtml = App.steps.map(step => {
        let statusClass = 'text-teal-200';
        let icon = 'far fa-circle';
        let iconBg = 'text-teal-200';

        if (step.id === App.currentStep) {
            statusClass = 'text-white font-bold';
            icon = 'fas fa-dot-circle';
            iconBg = 'text-white';
        } else if (step.id < App.currentStep) {
            statusClass = 'text-teal-300';
            icon = 'fas fa-check-circle';
            iconBg = 'text-teal-300';
        }

        return `
            <div class="flex items-center space-x-3 cursor-pointer" onclick="goToStep(${step.id})">
                <i class="${icon} text-lg ${iconBg}"></i>
                <span class="${statusClass}">${step.id}. ${step.title}</span>
            </div>
        `;
    }).join('');
    $('#wizard-steps').html(stepsHtml);
}

/**
 * Muestra un paso específico y oculta los demás.
 * @param {number} step El número del paso a mostrar.
 */
function goToStep(step) {
    // Validaciones para navegación hacia adelante
    if (step > App.currentStep) {
        if (App.currentStep === 1 && !App.selectedSede) {
            showAlert("Debes seleccionar una sede primero.", 'error');
            return;
        }
        // La validación y guardado/obtención de paciente_id se hace en el evento click de btn-step-2
        if (App.currentStep === 3) {
            if (!App.selectedDate || !App.selectedTime) {
                showAlert("Debes seleccionar una fecha y hora disponibles.", 'error');
                return;
            }
        }
    }
    
    // Si volvemos a un paso anterior (navegación manual)
    if (step < App.currentStep) {
        if (step === 1) {
            App.selectedSede = null;
            $('#btn-step-1').prop('disabled', true).html('Siguiente Paso <i class="fas fa-arrow-right ml-2"></i>');
        }
        if (step === 2 || step === 3) {
             App.selectedTime = null;
             $('#btn-step-3').prop('disabled', true);
        }
    }
    
    App.currentStep = step;
    $('#step-content').children().addClass('hidden');
    $(`#step-${step}`).removeClass('hidden');
    
    const currentStepConfig = App.steps.find(s => s.id === step);
    $('#step-title').text(currentStepConfig ? currentStepConfig.title : 'Sistema de Citas');

    updateWizardSteps();

    // Lógica específica para cada paso
    switch (step) {
        case 1:
            renderSedeList();
            break;
        case 2:
            // Cargar datos existentes si los hay
            $('#nombre').val(App.clientData.nombre || '');
            $('#email').val(App.clientData.email || '');
            $('#telefono').val(App.clientData.telefono || '');
            $('#nota').val(App.clientData.nota || '');
            $('#paciente-id').val(App.clientData.pacienteId || '');

            // Mostrar estado de búsqueda si existe un pacienteId
            if (App.clientData.pacienteId) {
                 $('#search-status').html('<i class="fas fa-check-circle mr-1 text-green-600"></i> Datos de paciente frecuente cargados.').removeClass('text-blue-700').addClass('text-green-700');
            } else {
                 $('#search-status').text('Busca tus datos con tu teléfono o correo si ya nos has visitado.').removeClass('text-green-700').addClass('text-blue-700');
            }

            break;
        case 3:
            $('#sede-name-step3').text(App.selectedSede ? App.selectedSede.nombre : 'N/A');
            if (!App.selectedDate || App.selectedDate.split('-')[0] != App.currentCalendarMonth.getFullYear() || App.selectedDate.split('-')[1] != (App.currentCalendarMonth.getMonth() + 1).toString().padStart(2, '0') ) {
                App.currentCalendarMonth = new Date();
            }
            renderCalendar(); 
            if (App.selectedDate) {
                generateTimeSlotsAndCheckAvailability(App.selectedDate);
            } else {
                $('#time-slots').empty().html('<p id="time-loading-message" class="col-span-full text-gray-500">Selecciona una fecha para ver las horas disponibles.</p>');
                $('#selected-date-display').text('');
            }
            break;
        case 4:
            updateStep4Summary();
            break;
    }
}

// --- PASO 1 LÓGICA (SEDE) ---

/**
 * Renderiza la lista de sedes disponibles usando App.allSedesData.
 */
function renderSedeList() {
    const listContainer = $('#sede-list');
    listContainer.empty();

    if (App.allSedesData.length === 0) {
        listContainer.html('<p class="col-span-full text-center text-red-500">No se encontraron sedes activas.</p>');
        $('#btn-step-1').prop('disabled', true);
        return;
    }

    App.allSedesData.forEach(sede => {
        const isSelected = App.selectedSede && App.selectedSede.id === sede.id;
        
        let horarioText = 'Horario no definido';
        try {
            const h = JSON.parse(sede.horario);
            const lv = h['lun-vie'];
            const sab = h['sab'];
            
            if (lv && lv.inicio && lv.fin && lv.inicio !== lv.fin) {
                horarioText = `L-V: ${lv.inicio} a ${lv.fin}`;
            } else if (lv === false) {
                horarioText = 'L-V: Cerrado';
            }
            
            if (sab && sab.inicio && sab.fin && sab.inicio !== sab.fin) {
                horarioText += (horarioText.includes('L-V') ? ' / ' : '') + `Sáb: ${sab.inicio} a ${sab.fin}`;
            } else if (sab === false) {
                 horarioText += (horarioText.includes('L-V') ? ' / ' : '') + `Sáb: Cerrado`;
            }
            
            if (!horarioText || horarioText.includes('Horario no definido')) {
                horarioText = 'Horario no definido';
            }

        } catch (e) {
            horarioText = 'Horario: N/A (Error de formato)';
        }

        const sedeCard = $(`
            <div class="interactable-card bg-white p-5 border-2 rounded-xl shadow-lg cursor-pointer hover:border-teal-500 ${isSelected ? 'selected-item' : 'border-gray-200'}" data-sede-id="${sede.id}">
                <h3 class="text-xl font-bold text-gray-800">${sede.nombre}</h3>
                <p class="text-sm text-gray-500 mt-1"><i class="fas fa-map-pin mr-1"></i> ${sede.direccion || 'Dirección no disponible'}</p>
                <p class="text-sm text-gray-500"><i class="fas fa-business-time mr-1"></i> ${horarioText}</p>
            </div>
        `);
        
        sedeCard.on('click', () => {
            App.selectedSede = sede;
            App.selectedDate = null;
            App.selectedTime = null;
            App.occupiedSlots = [];
            
            renderSedeList(); 
            $('#btn-step-1').prop('disabled', false).text(`Continuar con ${sede.nombre}`);
        });

        listContainer.append(sedeCard);
    });

    if (App.selectedSede) {
        $('#btn-step-1').prop('disabled', false).text(`Continuar con ${App.selectedSede.nombre}`);
    } else {
        $('#btn-step-1').prop('disabled', true).html('Siguiente Paso <i class="fas fa-arrow-right ml-2"></i>');
    }
}

// Evento de clic para el botón del Paso 1
$('#btn-step-1').on('click', () => goToStep(2));


// --- PASO 2 LÓGICA (PACIENTE FRECUENTE Y REGISTRO) ---

/**
 * Busca un paciente por email o teléfono y rellena el formulario.
 */
$('#btn-search-patient').on('click', function() {
    const searchData = $('#search-data').val().trim();
    if (searchData.length < 5) {
        showAlert("Ingresa un email o teléfono válido para buscar.", 'info');
        return;
    }
    
    const $btn = $(this);
    const $status = $('#search-status');
    $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i> Buscando...');
    $status.text('Buscando paciente...');
    
    // Asumimos un nuevo endpoint para buscar pacientes
    $.get("api/api-pacientes.php", {
        action: "find_by_data",
        query: searchData
    }, function(res) {
        if(res.success && res.data){
            const patient = res.data;
            
            // Rellenar los campos del formulario
            $('#nombre').val(patient.nombre || '');
            $('#email').val(patient.email || '');
            $('#telefono').val(patient.telefono || '');
            
            // Guardar el ID en el estado global y en el input oculto
            App.clientData.pacienteId = patient.id;
            $('#paciente-id').val(patient.id);
            
            $status.html('<i class="fas fa-check-circle mr-1 text-green-600"></i> ¡Datos encontrados! Paciente cargado.').removeClass('text-blue-700').addClass('text-green-700');
            showAlert("Datos de paciente frecuente cargados.", 'success');
        } else {
            // Si no se encuentra, limpiar ID y notificar
            App.clientData.pacienteId = null;
            $('#paciente-id').val('');
            
            $status.text('No se encontró paciente. Ingresa tus datos para registrarte automáticamente.').removeClass('text-green-700').addClass('text-red-700');
            showAlert("No se encontró paciente con esos datos. Por favor, rellena el formulario.", 'info');
        }
    }, "json").fail(() => {
        $status.text('Error de conexión al buscar paciente.').removeClass('text-green-700').addClass('text-red-700');
        showAlert("Error de conexión al buscar paciente. Intente de nuevo.", 'error');
    }).always(() => {
        $btn.prop('disabled', false).html('Buscar Datos');
    });
});


/**
 * Valida los datos del cliente y llama a la API para CREAR o ACTUALIZAR el paciente.
 * @returns {Promise<boolean>} Resuelve a true si el paciente_id fue creado/obtenido con éxito.
 */
function validateAndSavePatientData() {
    return new Promise(resolve => {
        const nombre = $('#nombre').val().trim();
        const email = $('#email').val().trim();
        const telefono = $('#telefono').val().trim();
        const nota = $('#nota').val().trim();
        const pacienteId = $('#paciente-id').val();
        
        // 1. Validaciones del formulario
        if (!nombre || !email || !telefono) {
            showAlert("Todos los campos obligatorios (Nombre, Email, Teléfono) deben ser completados.", 'error');
            return resolve(false);
        }
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(email)) {
            showAlert("Por favor, introduce un correo electrónico válido.", 'error');
            return resolve(false);
        }
        const phoneRegex = /^\d{7,}$/; 
        if (!phoneRegex.test(telefono.replace(/\s/g, ''))) {
            showAlert("Por favor, introduce un número de teléfono válido (mínimo 7 dígitos).", 'error');
            return resolve(false);
        }

        // 2. Guardar datos temporales en el estado
        App.clientData = { nombre, email, telefono, nota, pacienteId: pacienteId || null };

        // 3. Crear payload para la API (crear o actualizar)
        const apiData = {
            action: pacienteId ? "update_or_get" : "update_or_get", // Usamos un endpoint unificado
            id: pacienteId || null, 
            nombre: nombre,
            email: email,
            telefono: telefono
        };

        const $btn = $('#btn-step-2');
        $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin mr-2"></i> Procesando datos...');

        // 4. Llamada al backend para CREAR o ACTUALIZAR paciente y OBTENER ID
        $.post("api/api-pacientes.php", apiData, function(res) {
            if (res.success && res.paciente_id) {
                // Guardar el ID definitivo para la cita
                App.clientData.pacienteId = res.paciente_id;
                $('#paciente-id').val(res.paciente_id);
                resolve(true); // Éxito: tenemos un ID de paciente
            } else {
                showAlert(res.message || "Error al registrar/actualizar paciente. Intente de nuevo.", 'error');
                resolve(false);
            }
        }, "json").fail(xhr => {
            console.error("Error al procesar paciente:", xhr.responseText);
            showAlert("Error de conexión al procesar paciente. Contacte a soporte.", 'error');
            resolve(false);
        }).always(() => {
            $btn.prop('disabled', false).html('Siguiente Paso <i class="fas fa-arrow-right ml-2"></i>');
        });
    });
}

// Evento de clic para el botón del Paso 2
$('#btn-step-2').on('click', async function() {
    const success = await validateAndSavePatientData();
    if (success) {
        goToStep(3);
    }
});


// --- PASO 3 LÓGICA (CALENDARIO Y HORAS) ---

/**
 * Simula la inicialización del calendario usando la lógica de días.
 */
function renderCalendar() {
    const $daysContainer = $('#calendar-days').empty();
    const $monthYear = $('#currentMonthYear');
    const $prevBtn = $('#prevMonth');
    
    if (!App.selectedSede) return; 

    const today = new Date();
    today.setHours(0, 0, 0, 0); 
    
    const date = App.currentCalendarMonth;
    const currentMonth = date.getMonth();
    const currentYear = date.getFullYear();
    let horarios;
    try {
        horarios = JSON.parse(App.selectedSede.horario || '{}');
    } catch(e) {
        showAlert('Error: El formato de horario de la sede no es válido. No se puede cargar el calendario.', 'error');
        horarios = {};
    }
    
    const monthNames = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio",
                        "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
    
    // Deshabilitar botón Anterior si es el mes actual
    const firstDayOfCurrentMonth = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
    const firstDayOfVisibleMonth = new Date(currentYear, currentMonth, 1);
    $prevBtn.prop('disabled', firstDayOfVisibleMonth.getTime() <= firstDayOfCurrentMonth.getTime());

    $monthYear.text(`${monthNames[currentMonth]} ${currentYear}`);
    
    const firstDayOfMonth = new Date(currentYear, currentMonth, 1);
    const lastDayOfMonth = new Date(currentYear, currentMonth + 1, 0);
    const startDay = firstDayOfMonth.getDay(); // 0 (Dom) to 6 (Sáb)
    
    // Rellenar espacios vacíos
    for (let i = 0; i < startDay; i++) {
        $daysContainer.append('<div class="h-10"></div>');
    }

    // Renderizar días
    for (let day = 1; day <= lastDayOfMonth.getDate(); day++) {
        const currentDate = new Date(currentYear, currentMonth, day);
        currentDate.setHours(0, 0, 0, 0); 
        const dateISO = currentDate.toISOString().split('T')[0];
        
        let classes = 'day-card h-10 flex items-center justify-center rounded-full text-sm font-semibold transition duration-200 border-2 border-transparent';
        let isDisabled = false;

        // 1. Deshabilitar fechas pasadas
        if (currentDate.getTime() < today.getTime()) {
            classes += ' disabled';
            isDisabled = true;
        }

        // 2. Deshabilitar días no laborables basados en el JSON de horario
        if (!isDisabled) {
            const dayKey = getHorarioKey(currentDate);
            const horarioDia = horarios[dayKey];
            
            if (horarioDia === false || !horarioDia || !horarioDia.inicio || !horarioDia.fin || horarioDia.inicio === horarioDia.fin) {
                classes += ' disabled';
                isDisabled = true;
            }
        }
        
        // 3. Resaltar el día de hoy
        if (currentDate.getTime() === today.getTime() && !isDisabled) {
            classes += ' today border-yellow-500';
        }

        // 4. Resaltar día seleccionado
        if (App.selectedDate === dateISO) {
            classes += ' selected-item !border-teal-600 bg-teal-50';
        } else if (!isDisabled) {
            classes += ' hover:bg-teal-100 cursor-pointer text-gray-800 border-teal-200';
        } else {
            classes += ' text-gray-400';
        }
        
        const dayHtml = $(`<div class="${classes}" data-date="${dateISO}">${day}</div>`);
        
        if (!isDisabled) {
            dayHtml.on('click', function() {
                $('.day-card').removeClass('selected-item !border-teal-600 bg-teal-50');
                $(this).addClass('selected-item !border-teal-600 bg-teal-50');
                
                App.selectedDate = $(this).data('date');
                App.selectedTime = null; 
                $('#btn-step-3').prop('disabled', true);
                
                generateTimeSlotsAndCheckAvailability(App.selectedDate);
            });
        }
        
        $daysContainer.append(dayHtml);
    }
    
    // Listeners para navegación del calendario
    $('#prevMonth, #nextMonth').off('click');
    $('#prevMonth').on('click', function() {
        if ($(this).prop('disabled')) return;
        App.currentCalendarMonth = new Date(App.currentCalendarMonth.getFullYear(), App.currentCalendarMonth.getMonth() - 1, 1);
        renderCalendar();
    });

    $('#nextMonth').on('click', function() {
        App.currentCalendarMonth = new Date(App.currentCalendarMonth.getFullYear(), App.currentCalendarMonth.getMonth() + 1, 1);
        renderCalendar();
    });
}


/**
 * Genera los slots de tiempo basándose en el horario de la sede y verifica su disponibilidad usando la API.
 */
async function generateTimeSlotsAndCheckAvailability(fecha) {
    const slotsContainer = $('#time-slots');
    slotsContainer.empty();
    $('#selected-date-display').text(fecha);

    if (!App.selectedSede) return;
    
    slotsContainer.html('<p class="col-span-full text-center text-teal-600"><i class="fas fa-sync-alt fa-spin mr-2"></i> Buscando horas disponibles...</p>');
    $('#btn-step-3').prop('disabled', true);
    
    try {
        const sede = App.selectedSede;
        const horarios = JSON.parse(sede.horario || '{}');
        const dateObj = new Date(fecha + 'T00:00:00'); 
        const dayKey = getHorarioKey(dateObj);
        const horarioDia = horarios[dayKey];

        await getOccupiedSlotsForDay(sede.id, fecha);
        
        if (!horarioDia || !horarioDia.inicio || !horarioDia.fin || horarioDia.inicio === horarioDia.fin || horarioDia === false) {
            slotsContainer.html('<p class="col-span-full text-red-500"><i class="fas fa-times-circle mr-2"></i>Día no laborable o sin horario configurado.</p>');
            return;
        }

        let timeSlots = [];
        let current = new Date(fecha + 'T' + horarioDia.inicio + ':00');
        let end = new Date(fecha + 'T' + horarioDia.fin + ':00');
        const now = new Date();
        
        // Generar slots de 60 minutos
        while (current < end) {
            let slotEnd = new Date(current);
            slotEnd.setMinutes(slotEnd.getMinutes() + 60);

            if (slotEnd > end) break; 
            
            const timeString = current.toTimeString().substring(0, 5); 
            
            // Solo slots futuros (dando un margen de 5 minutos al tiempo actual)
            if (current.getTime() > (now.getTime() - 5 * 60 * 1000)) { 
                 timeSlots.push(timeString);
            }
            
            current.setMinutes(current.getMinutes() + 60); 
        }

        if (timeSlots.length === 0) {
            slotsContainer.html('<p class="col-span-full text-red-500"><i class="fas fa-calendar-times mr-2"></i>No hay horas disponibles o ya pasaron hoy.</p>');
            return;
        }
        
        slotsContainer.empty();
        let availableSlotsCount = 0;
        
        // Renderizar slots y chequear contra App.occupiedSlots
        timeSlots.forEach(time => {
             const isAvailable = !App.occupiedSlots.includes(time);
             
             let classes = "time-slot";
             
             if (isAvailable) {
                 availableSlotsCount++;
                 const isSelected = App.selectedTime === time;
                 classes += ` available ${isSelected ? 'selected-item !bg-teal-600 !text-white' : ''}`;
             } else {
                 classes += " unavailable";
             }

             const slotButton = $(`
                 <button class="${classes}" data-time="${time}" data-available="${isAvailable}">
                     ${time}
                 </button>
             `);
             
             if (isAvailable) {
                 slotButton.on('click', function() {
                     $('.time-slot.available').removeClass('selected-item !bg-teal-600 !text-white');
                     $(this).addClass('selected-item !bg-teal-600 !text-white');
                     
                     App.selectedTime = time;
                     $('#btn-step-3').prop('disabled', false);
                 });
             } else {
                 slotButton.prop('title', 'Slot no disponible');
             }
             
             slotsContainer.append(slotButton);
        });

        if (availableSlotsCount === 0) {
            slotsContainer.html('<p class="col-span-full text-red-500"><i class="fas fa-calendar-times mr-2"></i>Todas las horas disponibles están reservadas para este día.</p>');
        }
        
    } catch (e) {
        console.error("Error al procesar el horario o disponibilidad:", e);
        slotsContainer.html('<p class="col-span-full text-red-500"><i class="fas fa-exclamation-triangle mr-2"></i>Error al cargar la disponibilidad. Revise el formato del horario.</p>');
    }
}

// Evento de clic para el botón del Paso 3
$('#btn-step-3').on('click', () => {
    goToStep(4);
});


// --- PASO 4 LÓGICA (CONFIRMACIÓN Y ENVÍO) ---

/**
 * Actualiza el resumen del Paso 4 con los datos del App state.
 */
function updateStep4Summary() {
    // Sede
    $('#step-4-sede').text(App.selectedSede ? App.selectedSede.nombre : 'Sede no seleccionada');
    
    // Fecha y Hora
    let dateDisplay = 'N/A';
    if (App.selectedDate) {
        const parts = App.selectedDate.split('-');
        const dateObj = new Date(parts[0], parts[1] - 1, parts[2]); 

        dateDisplay = dateObj.toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    }
    $('#step-4-date').text(dateDisplay);
    $('#step-4-time').text(App.selectedTime || 'Hora no seleccionada');
    
    // Datos Personales
    $('#step-4-nombre').text(App.clientData.nombre || 'N/A');
    $('#step-4-email').text(App.clientData.email || 'N/A');
    $('#step-4-telefono').text(App.clientData.telefono || 'N/A');
    $('#step-4-nota').text(App.clientData.nota || 'Ninguna');
}

/**
 * Manejador del envío final de la cita.
 */
$('#btn-submit').on('click', function() {
    // Validación crucial: nos aseguramos de que el pacienteId se haya obtenido/creado
    if (!App.clientData.pacienteId || !App.selectedDate || !App.selectedTime || !App.selectedSede) {
        showAlert("Faltan datos de la cita, paciente, o ubicación. Por favor, revisa los pasos anteriores.", 'error');
        return;
    }

    const data = {
        action: "save", 
        // ¡NUEVO!: Se envía el ID del paciente, no sus datos personales directos
        paciente_id: App.clientData.pacienteId, 
        sede_id: App.selectedSede.id,
        notas: App.clientData.nota || '',
        // Asumiendo que el campo creado_por_usuario_id es NULLable, no lo enviamos
        // Si no está logueado un admin.
        
        // Formato final requerido por el backend (YYYY-MM-DD HH:MM:SS)
        fecha: `${App.selectedDate} ${App.selectedTime}:00` 
    };

    const $btn = $(this);
    $btn.prop('disabled', true).html('<i class="fas fa-sync-alt fa-spin mr-2"></i> Confirmando...');

    // --- LLAMADA FINAL AL BACKEND PARA AGENDAR ---
    $.post("api/api-citas.php", data, function(res){
        if(res.success){
            showAlert(res.message || "Cita agendada correctamente. Revise su correo electrónico.", 'success');
            
            // Reiniciar el App state
            App.clientData = { pacienteId: null, nombre: null, email: null, telefono: null, nota: null };
            App.selectedSede = null;
            App.selectedDate = null;
            App.selectedTime = null;
            App.currentCalendarMonth = new Date();
            App.occupiedSlots = [];
            
            // Volver al paso 1
            goToStep(1); 
        } else {
            showAlert(res.message || "Error al agendar la cita. Intente de nuevo.", 'error');
        }
    },"json").fail(xhr=>{
        console.error("Error al agendar cita:", xhr.responseText);
        try {
            const res = JSON.parse(xhr.responseText);
            showAlert(res.message || "Error de conexión con el servidor al agendar. Contacte a soporte.", 'error');
        } catch (e) {
            showAlert("Error de conexión con el servidor al agendar. Contacte a soporte.", 'error');
        }
    }).always(() => {
        $btn.prop('disabled', false).html('Confirmar Cita');
    });
});


// --- INICIALIZACIÓN Y CARGA DE DATOS REALES ---

$(document).ready(function() {
    // 1. Cargar Sedes desde la API
    $.get('api/api-sedes.php', {action:'list', activos:1, include_horario: 1}, function(res){
        if(res.success && res.data && res.data.length > 0){
            App.allSedesData = res.data;
            goToStep(1); // Iniciar el wizard en el paso 1 con datos cargados
        } else {
             showAlert('No se pudieron cargar las sedes disponibles. Intente más tarde.', 'error');
             $('#sede-list').html('<p class="col-span-full text-center text-red-500">No se encontraron sedes activas o el API falló.</p>');
             $('#btn-step-1').prop('disabled', true);
        }
    }, "json").fail(() => {
        showAlert('Error de conexión al cargar las sedes.', 'error');
        $('#btn-step-1').prop('disabled', true);
    });
});
</script>
