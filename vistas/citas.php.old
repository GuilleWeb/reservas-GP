                            <p class="text-gray-700"><span class="font-semibold">Email:</span> <strong id="step-4-email" class="text-gray-900">N/A</strong></p>
                            <p class="text-gray-700"><span class="font-semibold">Teléfono:</span> <strong id="step-4-telefono" class="text-gray-900">N/A</strong></p>
