}

/* Estilos para los slots de tiempo */
.time-slot {
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    font-weight: 600;
    text-align: center;
    transition: all 0.2s;
}

.time-slot.available {
    cursor: pointer;
    background-color: #ecfdf5; /* Verde muy claro */
    color: #047857; /* Verde oscuro */
    border: 1px solid #10b981;
}

.time-slot.available:hover {
    background-color: #047857;
    color: white;
}

.time-slot.unavailable {
    background-color: #fef2f2; /* Rojo muy claro */
    color: #ef4444; /* Rojo oscuro */
    border: 1px dashed #f87171;
    cursor: not-allowed;
}

/* SCROLL VERTICAL PARA SEDES */
#sede-list-wrapper {
    max-height: 24rem; 
    overflow-y: auto;
    padding-right: 0.5rem; 
}

/* Estilo para el botón de búsqueda de paciente */
#btn-search-patient {
    transition: background-color 0.2s, transform 0.2s;
}
</style>

