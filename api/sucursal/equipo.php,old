<?php
require_once __DIR__ . '/../../helpers.php';
header('Content-Type: application/json; charset=utf-8');

$action = $_REQUEST['action'] ?? '';
$user = current_user();
$empresa_slug = request_empresa_slug();
$roles_permitidos = ['superadmin', 'admin', 'gerente'];
if (!$user || !$empresa_slug || !in_array($user['rol'] ?? null, $roles_permitidos)) {
    json_response(['error' => 'unauthorized'], 403);
}

$empresa_id = (int) ($user['empresa_id'] ?? 0);
$sucursal_id_filtro = (int) ($user['sucursal_id'] ?? 0);

switch ($action) {
    case 'list':
        $where = ['empresa_id = ?'];
        $params = [$empresa_id];
        if ($sucursal_id_filtro > 0) {
            $where[] = 'sucursal_id = ?';
            $params[] = $sucursal_id_filtro;
        }
        $whereSql = implode(' AND ', $where);
        $stmt = $pdo->prepare("SELECT * FROM equipo WHERE $whereSql ORDER BY nombre ASC");
        $stmt->execute($params);
        $data = $stmt->fetchAll(PDO::FETCH_ASSOC);
        json_response(['success' => true, 'data' => $data, 'total' => count($data)]);
        break;

    case 'get':
        $id = (int) ($_GET['id'] ?? 0);
        $stmt = $pdo->prepare('SELECT * FROM equipo WHERE id = ? AND empresa_id = ?');
        $stmt->execute([$id, $empresa_id]);
        json_response(['success' => true, 'data' => $stmt->fetch(PDO::FETCH_ASSOC) ?: []]);
        break;

    case 'save':
        if (($_SERVER['REQUEST_METHOD'] ?? '') !== 'POST')
            json_response(['error' => 'invalid_method'], 405);

        $id = (int) ($_POST['id'] ?? 0);
        $nombre = trim($_POST['nombre'] ?? '');
        $especialidad = trim($_POST['especialidad'] ?? '');
        $bio = trim($_POST['bio'] ?? '');
        $visible = (int) ($_POST['visible_en_home'] ?? 0);

        if (!$nombre)
            json_response(['success' => false, 'message' => 'Nombre obligatorio.']);

        if ($id > 0) {
            $stmt = $pdo->prepare('UPDATE equipo SET nombre=?, especialidad=?, bio=?, visible_en_home=? WHERE id=? AND empresa_id=?');
            $stmt->execute([$nombre, $especialidad, $bio, $visible, $id, $empresa_id]);
        } else {
            $stmt = $pdo->prepare('INSERT INTO equipo (empresa_id, sucursal_id, nombre, especialidad, bio, visible_en_home) VALUES (?,?,?,?,?,?)');
            $stmt->execute([$empresa_id, $sucursal_id_filtro ?: null, $nombre, $especialidad, $bio, $visible]);
            $id = (int) $pdo->lastInsertId();
        }
        json_response(['success' => true, 'id' => $id]);
        break;

    case 'delete':
        $id = (int) ($_POST['id'] ?? 0);
        $stmt = $pdo->prepare('DELETE FROM equipo WHERE id = ? AND empresa_id = ?');
        $stmt->execute([$id, $empresa_id]);
        json_response(['success' => true]);
        break;

    default:
        json_response(['error' => 'invalid_action'], 400);
}
