<?php
require_once __DIR__.'/../helpers.php';
header('Content-Type: application/json; charset=utf-8');

$action = $_REQUEST['action'] ?? '';
$csrf = $_REQUEST['csrf_token'] ?? '';
$user = current_user();

//if(!$user) json_response(['error'=>'unauthorized'],403);

switch($action){
    case 'list':
        $page = max(1,intval($_GET['page']??1));
        $per = max(1,intval($_GET['per']??10));
        $search = $_GET['search']??'';
        $only_active = isset($_GET['active_only']) ? "AND activo=1" : "";

        $where = $search ? "WHERE nombre LIKE :s OR direccion LIKE :s $only_active" : ($only_active ? "WHERE activo=1" : "");
        $stmt = $pdo->prepare("SELECT COUNT(*) FROM sedes $where");
        if($search) $stmt->execute(['s'=>"%$search%"]); else $stmt->execute();
        $total = $stmt->fetchColumn();
        $total_pages = ceil($total/$per);

        $offset = ($page-1)*$per;
        $sql = "SELECT * FROM sedes $where ORDER BY id DESC LIMIT :o,:p";
        $stmt = $pdo->prepare($sql);
        if($search) $stmt->bindValue(':s', "%$search%", PDO::PARAM_STR);
        $stmt->bindValue(':o',$offset,PDO::PARAM_INT);
        $stmt->bindValue(':p',$per,PDO::PARAM_INT);
        $stmt->execute();
        $data = $stmt->fetchAll(PDO::FETCH_ASSOC);

        // list
        json_response([
            'success' => true,
            'data' => $data,
            'total' => $total,       // total de registros
            'total_pages' => $total_pages
        ]);
        break;

    case 'get':
        $id = intval($_GET['id']??0);
        $stmt = $pdo->prepare("SELECT * FROM sedes WHERE id=?");
        $stmt->execute([$id]);
        json_response(['success' => true,'data' => $stmt->fetch() ?: []]);
        break;

    case 'save':
        if(!$user || !has_permission('permiso_crear')) json_response(['error'=>'unauthorized'],403);

        $id = intval($_POST['id'] ?? 0);
        $nombre = $_POST['nombre'] ?? '';
        $direccion = $_POST['direccion'] ?? '';
        $telefono = $_POST['telefono'] ?? '';
        $horario = $_POST['horario'] ?? '';
        $activo = isset($_POST['activo']) ? 1 : 0;

        $rutaImg = null;

        // Procesar imagen si se envía
        if(!empty($_FILES['imagen']['name'])){
            $dir = __DIR__ . '/../assets/sedes/';
            if(!is_dir($dir)) mkdir($dir, 0777, true);
            $ext = pathinfo($_FILES['imagen']['name'], PATHINFO_EXTENSION);
            $nombreArchivo = 'sede_' . time() . '.' . strtolower($ext);
            $ruta = $dir . $nombreArchivo;
            if(move_uploaded_file($_FILES['imagen']['tmp_name'], $ruta)){
                $rutaImg = 'assets/sedes/' . $nombreArchivo;
            }
        }

        if($id > 0){
            // Si no se subió nueva imagen, mantener la existente
            if(!$rutaImg){
                $stmt = $pdo->prepare("UPDATE sedes SET nombre=?,direccion=?,telefono=?,horario=?,activo=? WHERE id=?");
                $stmt->execute([$nombre,$direccion,$telefono,$horario,$activo,$id]);
            } else {
                $stmt = $pdo->prepare("UPDATE sedes SET nombre=?,direccion=?,telefono=?,horario=?,activo=?,imagen=? WHERE id=?");
                $stmt->execute([$nombre,$direccion,$telefono,$horario,$activo,$rutaImg,$id]);
            }
        } else {
            $stmt = $pdo->prepare("INSERT INTO sedes(nombre,direccion,telefono,horario,activo,imagen) VALUES(?,?,?,?,?,?)");
            $stmt->execute([$nombre,$direccion,$telefono,$horario,$activo,$rutaImg]);
        }

        json_response(['success' => true]);
        break;


    case 'delete':
        if(!$user || !has_permission('permiso_borrar')) json_response(['error'=>'unauthorized'],403);
        $id = intval($_POST['id']??0);
        $stmt = $pdo->prepare("DELETE FROM sedes WHERE id=?");
        $stmt->execute([$id]);
        json_response(['success'=>true]);
        break;

    default:
        json_response(['error'=>'invalid_action'],400);
}
