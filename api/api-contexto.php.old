<?php
require_once __DIR__.'/../helpers.php';
header('Content-Type: application/json; charset=utf-8');

$action = $_REQUEST['action'] ?? '';
$ctx = tenant_context();
$empresa_slug = $ctx['empresa_slug'];
$sucursal_slug = $ctx['sucursal_slug'] ?? ($_GET['sucursal_slug'] ?? null);

switch ($action) {
    case 'resolve_empresa':
        if (!$empresa_slug) json_response(['success' => false, 'error' => 'missing_empresa'], 400);
        $stmt = $pdo->prepare('SELECT id, slug, nombre, activo FROM empresas WHERE slug = ? LIMIT 1');
        $stmt->execute([$empresa_slug]);
        $empresa = $stmt->fetch(PDO::FETCH_ASSOC);
        if (!$empresa) json_response(['success' => false, 'error' => 'empresa_not_found'], 404);
        if (empty($empresa['activo'])) json_response(['success' => false, 'error' => 'empresa_inactiva'], 403);
        json_response(['success' => true, 'data' => $empresa]);
        break;

    case 'resolve_sucursal':
        if (!$empresa_slug) json_response(['success' => false, 'error' => 'missing_empresa'], 400);
        if (!$sucursal_slug) json_response(['success' => false, 'error' => 'missing_sucursal'], 400);

        $stmt = $pdo->prepare('SELECT id, slug, nombre, activo FROM empresas WHERE slug = ? LIMIT 1');
        $stmt->execute([$empresa_slug]);
        $empresa = $stmt->fetch(PDO::FETCH_ASSOC);
        if (!$empresa) json_response(['success' => false, 'error' => 'empresa_not_found'], 404);
        if (empty($empresa['activo'])) json_response(['success' => false, 'error' => 'empresa_inactiva'], 403);

        $stmt = $pdo->prepare('SELECT id, empresa_id, slug, nombre, activo FROM sucursales WHERE empresa_id = ? AND slug = ? LIMIT 1');
        $stmt->execute([$empresa['id'], $sucursal_slug]);
        $sucursal = $stmt->fetch(PDO::FETCH_ASSOC);
        if (!$sucursal) json_response(['success' => false, 'error' => 'sucursal_not_found'], 404);
        if (empty($sucursal['activo'])) json_response(['success' => false, 'error' => 'sucursal_inactiva'], 403);

        json_response([
            'success' => true,
            'data' => [
                'empresa' => $empresa,
                'sucursal' => $sucursal
            ]
        ]);
        break;

    default:
        json_response(['error' => 'invalid_action'], 400);
}
