<?php
// api/roles.php
require_once __DIR__ . '/../helpers.php';
header('Content-Type: application/json; charset=utf-8');

$csrfToken = $_SERVER['HTTP_X_CSRF_TOKEN'] ?? $_REQUEST['csrf_token'] ?? null;
if(!verify_csrf($csrfToken)) {
    json_response(['error' => 'invalid_csrf'], 403);
}

$action = $_REQUEST['action'] ?? '';

if($action === 'list') {
    $stmt = $pdo->query("SELECT * FROM roles ORDER BY id ASC");
    json_response(['success'=>true,'data'=>$stmt->fetchAll()]);
}

if($action === 'get') {
    $id = intval($_GET['id'] ?? 0);
    $stmt = $pdo->prepare("SELECT * FROM roles WHERE id = ?");
    $stmt->execute([$id]);
    json_response(['success'=>true,'data'=>$stmt->fetch()]);
}

if($action === 'create') {
    if(!has_permission('permiso_crear')) json_response(['error'=>'no_perm'],403);
    $nombre = trim($_POST['nombre_rol'] ?? '');
    $crear = !empty($_POST['permiso_crear']) ? 1 : 0;
    $leer = !empty($_POST['permiso_leer']) ? 1 : 0;
    $act = !empty($_POST['permiso_actualizar']) ? 1 : 0;
    $borrar = !empty($_POST['permiso_borrar']) ? 1 : 0;
    if($nombre === '') json_response(['error'=>'nombre_required'],400);
    $stmt = $pdo->prepare("INSERT INTO roles (nombre_rol, permiso_crear, permiso_leer, permiso_actualizar, permiso_borrar) VALUES (?, ?, ?, ?, ?)");
    $stmt->execute([$nombre,$crear,$leer,$act,$borrar]);
    json_response(['success'=>true,'id'=>$pdo->lastInsertId()],201);
}

if($action === 'update') {
    if(!has_permission('permiso_actualizar')) json_response(['error'=>'no_perm'],403);
    $id = intval($_POST['id'] ?? 0);
    $nombre = trim($_POST['nombre_rol'] ?? '');
    $crear = !empty($_POST['permiso_crear']) ? 1 : 0;
    $leer = !empty($_POST['permiso_leer']) ? 1 : 0;
    $act = !empty($_POST['permiso_actualizar']) ? 1 : 0;
    $borrar = !empty($_POST['permiso_borrar']) ? 1 : 0;
    $stmt = $pdo->prepare("UPDATE roles SET nombre_rol=?, permiso_crear=?, permiso_leer=?, permiso_actualizar=?, permiso_borrar=? WHERE id = ?");
    $stmt->execute([$nombre,$crear,$leer,$act,$borrar,$id]);
    json_response(['success'=>true]);
}

if($action === 'delete') {
    if(!has_permission('permiso_borrar')) json_response(['error'=>'no_perm'],403);
    $id = intval($_POST['id'] ?? 0);
    $stmt = $pdo->prepare("DELETE FROM roles WHERE id = ?");
    $stmt->execute([$id]);
    json_response(['success'=>true,'deleted'=>$id]);
}

json_response(['error'=>'invalid_action'],400);
