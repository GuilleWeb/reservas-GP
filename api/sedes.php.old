<?php
// api/sedes.php
require_once __DIR__ . '/../helpers.php';
header('Content-Type: application/json; charset=utf-8');

$method = $_SERVER['REQUEST_METHOD'];
$action = $_REQUEST['action'] ?? '';

$csrfToken = $_SERVER['HTTP_X_CSRF_TOKEN'] ?? $_REQUEST['csrf_token'] ?? null;
if(!verify_csrf($csrfToken)) {
    json_response(['error' => 'invalid_csrf'], 403);
}

switch ($action) {
  case 'list':
    // listar sedes
    $stmt = $pdo->query("SELECT * FROM sedes ORDER BY id DESC");
    $rows = $stmt->fetchAll();
    json_response(['success'=>true, 'data'=>$rows]);
    break;

  case 'get':
    $id = intval($_GET['id'] ?? 0);
    $stmt = $pdo->prepare("SELECT * FROM sedes WHERE id = ? LIMIT 1");
    $stmt->execute([$id]);
    $row = $stmt->fetch();
    if(!$row) json_response(['error'=>'not_found'], 404);
    json_response(['success'=>true, 'data'=>$row]);
    break;

  case 'create':
    if(!has_permission('permiso_crear')) json_response(['error'=>'no_perm'],403);
    $nombre = trim($_POST['nombre'] ?? '');
    $direccion = trim($_POST['direccion'] ?? '');
    $telefono = trim($_POST['telefono'] ?? null);
    $horario = trim($_POST['horario'] ?? null);

    if($nombre === '') json_response(['error'=>'nombre_required'],400);

    $stmt = $pdo->prepare("INSERT INTO sedes (nombre,direccion,telefono,horario,activo) VALUES (?,?,?,?,1)");
    $stmt->execute([$nombre,$direccion,$telefono,$horario]);
    $id = $pdo->lastInsertId();
    $stmt = $pdo->prepare("SELECT * FROM sedes WHERE id = ?");
    $stmt->execute([$id]);
    $nuevo = $stmt->fetch();
    json_response(['success'=>true, 'data'=>$nuevo],201);
    break;

  case 'update':
    if(!has_permission('permiso_actualizar')) json_response(['error'=>'no_perm'],403);
    $id = intval($_POST['id'] ?? 0);
    $nombre = trim($_POST['nombre'] ?? '');
    $direccion = trim($_POST['direccion'] ?? '');
    $telefono = trim($_POST['telefono'] ?? null);
    $horario = trim($_POST['horario'] ?? null);

    $stmt = $pdo->prepare("UPDATE sedes SET nombre=?, direccion=?, telefono=?, horario=? WHERE id = ?");
    $stmt->execute([$nombre,$direccion,$telefono,$horario,$id]);
    $stmt = $pdo->prepare("SELECT * FROM sedes WHERE id = ?");
    $stmt->execute([$id]);
    json_response(['success'=>true, 'data'=>$stmt->fetch()]);
    break;

  case 'delete':
    if(!has_permission('permiso_borrar')) json_response(['error'=>'no_perm'],403);
    $id = intval($_POST['id'] ?? 0);
    $stmt = $pdo->prepare("DELETE FROM sedes WHERE id = ?");
    $stmt->execute([$id]);
    json_response(['success'=>true, 'deleted_id'=>$id]);
    break;

  default:
    json_response(['error'=>'invalid_action'],400);
}
