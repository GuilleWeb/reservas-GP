RewriteEngine On
RewriteBase /clinica/

# si es archivo o directorio existente, lo sirve directo
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# DEV: desactivado el router por .htaccess para trabajar con rutas por archivo
# RewriteRule ^(.*)$ index.php?r=$1 [QSA,L]
